    <!-- Onboarding - Step 2: Camera -->
    <string name="onboarding_camera_title">Camera Access</string>
    <string name="onboarding_camera_rationale">AirControl uses your front camera to track hand movements and recognize gestures in real time. Your camera feed is processed entirely on-device and never recorded or transmitted.</string>
